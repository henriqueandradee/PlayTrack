# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Database ----
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>

# ---- CORS ----
# Development example: http://localhost:5173
# Production example: https://app.example.com,https://api.example.com
CORS_ORIGIN=http://localhost:5173

# ---- Auth ----
JWT_SECRET=replace_with_a_random_32_plus_char_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- Email ----
EMAIL_VALIDATION_MODE=format-only
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com

# ---- Public URLs ----
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000

# ---- Integrations ----
YOUTUBE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ---- Freemium ----
FREE_MAX_VIDEOS=3
FREE_MAX_EVENTS_PER_VIDEO=200

# ---- Export tools ----
YTDLP_PATH=
FFMPEG_PATH=
EXPORT_YTDLP_TIMEOUT_MS=600000
EXPORT_FFMPEG_TIMEOUT_MS=900000
EXPORT_MAX_CONCURRENT_JOBS=1
